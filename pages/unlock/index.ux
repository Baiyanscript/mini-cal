    <text class="title">解锁码计算</text>

    <div class="field-row">
      <div if="{{activeField=='mac'}}" class="field-chip field-chip-active" onclick="selectField('mac')">
        <text class="field-label">MAC</text>
        <text class="field-value">{{macDisplay == '' ? '未输入' : macDisplay}}</text>
