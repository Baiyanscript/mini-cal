      </div>
    </div>

    <div if="{{kbMode=='symbol'}}" class="keypad">
      <div class="krow">
        <div class="kbtn" onclick="pressChar('-')"><text class="kbtn-text">-</text></div>
        <div class="kbtn" onclick="pressChar('_')"><text class="kbtn-text">_</text></div>
        <div class="kbtn" onclick="pressChar('.')"><text class="kbtn-text">.</text></div>
        <div class="kbtn" onclick="pressChar(':')"><text class="kbtn-text">:</text></div>
        <div class="kbtn" onclick="pressChar('/')"><text class="kbtn-text">/</text></div>
        <div class="kbtn" onclick="pressChar('\\\\')"><text class="kbtn-text">\</text></div>
      </div>
      <div class="krow">
        <div class="kbtn" onclick="pressChar('@')"><text class="kbtn-text">@</text></div>
        <div class="kbtn" onclick="pressChar('#')"><text class="kbtn-text">#</text></div>
        <div class="kbtn" onclick="pressChar('$')"><text class="kbtn-text">$</text></div>
        <div class="kbtn" onclick="pressChar('%')"><text class="kbtn-text">%</text></div>
        <div class="kbtn" onclick="pressChar('&amp;')"><text class="kbtn-text">&amp;</text></div>
        <div class="kbtn" onclick="pressChar('*')"><text class="kbtn-text">*</text></div>
      </div>
      <div class="krow">
        <div class="kbtn" onclick="pressChar('+')"><text class="kbtn-text">+</text></div>
        <div class="kbtn" onclick="pressChar('=')"><text class="kbtn-text">=</text></div>
        <div class="kbtn" onclick="pressChar('!')"><text class="kbtn-text">!</text></div>
        <div class="kbtn" onclick="pressChar('?')"><text class="kbtn-text">?</text></div>
        <div class="kbtn" onclick="pressChar('(')"><text class="kbtn-text">(</text></div>
        <div class="kbtn" onclick="pressChar(')')"><text class="kbtn-text">)</text></div>
      </div>
      <div class="krow">
        <div class="kbtn" onclick="pressChar('[')"><text class="kbtn-text">[</text></div>
        <div class="kbtn" onclick="pressChar(']')"><text class="kbtn-text">]</text></div>
        <div class="kbtn" onclick="pressChar('{')"><text class="kbtn-text">{</text></div>
        <div class="kbtn" onclick="pressChar('}')"><text class="kbtn-text">}</text></div>
        <div class="kbtn" onclick="pressChar('~')"><text class="kbtn-text">~</text></div>
        <div class="kbtn" onclick="pressChar('^')"><text class="kbtn-text">^</text></div>
      </div>
