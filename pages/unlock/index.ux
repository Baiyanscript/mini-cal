</style>

<script>
import router from '@system.router'
import { vibrateShort } from '../../common/js/vibrate'
import { calcUnlockCode } from '../../common/js/unlock'

export default {
  data: {
    time: '',
    activeField: 'mac',
    kbMode: 'alnum',
    mac: '',
    sn: '',
    macDisplay: '',
    useNewAlgo: false,
    code: ''
  },

  updateTime() {
    var date = new Date()
    var hour = String(date.getHours()).padStart(2, '0')
    var minute = String(date.getMinutes()).padStart(2, '0')
    this.time = hour + ':' + minute
  },

  onInit() {
    this.updateTime()
    this.timer = setInterval(() => {
      this.updateTime()
    }, 60000)
  },

  onShow() {
    this.updateTime()
  },

  onDestroy() {
    clearInterval(this.timer)
  },

  blockSwipe() {
    // 攔截滑動手勢
  },

  goBack() {
    vibrateShort()
    router.back()
  },

  selectField(field) {
    vibrateShort()
    this.activeField = field
  },

  setMode(mode) {
    vibrateShort()
    this.kbMode = mode
  },

  updateMacDisplay() {
    this.macDisplay = this.mac.replace(/(.{2})/g, '$1:').replace(/:$/, '')
  },

  pressChar(ch) {
    vibrateShort()
    if (this.activeField === 'mac') {
      if (this.mac.length >= 12) return
      this.mac = this.mac + ch
      this.updateMacDisplay()
    } else {
      if (this.sn.length >= 20) return
      this.sn = this.sn + ch
    }
    this.code = ''
  },

  backspace() {
    vibrateShort()
    if (this.activeField === 'mac') {
      this.mac = this.mac.slice(0, -1)
      this.updateMacDisplay()
    } else {
      this.sn = this.sn.slice(0, -1)
    }
    this.code = ''
  },

  clearField() {
    vibrateShort()
    if (this.activeField === 'mac') {
      this.mac = ''
      this.macDisplay = ''
    } else {
      this.sn = ''
    }
    this.code = ''
  },

  toggleAlgo() {
    vibrateShort()
    this.useNewAlgo = !this.useNewAlgo
    this.code = ''
  },

  calc() {
    vibrateShort()
    if (!this.mac) {
      this.code = ''
      return
    }
    if (!this.sn) {
      this.code = ''
      return
    }
    this.code = calcUnlockCode(this.mac, this.sn, this.useNewAlgo)
  }
}
</script>
