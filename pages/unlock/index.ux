  font-size: 12px;
  font-weight: 600;
  color: #FFFFFF;
}

.mode-row {
  width: 168px;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 4px;
  margin-top: 2px;
}

.mode-chip {
  flex: 1;
  height: 24px;
  margin-right: 6px;
  border-radius: 12px;
  background-color: #262626;
  justify-content: center;
  align-items: center;
  border-width: 1.5px;
  border-style: solid;
  border-color: rgba(255, 255, 255, 0.18);
}

.mode-chip-active {
  background-color: #007AFF;
}

.mode-text {
  font-size: 11px;
  font-weight: 600;
  color: #FFFFFF;
}

.toggle-row {
  width: 168px;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4px;
  margin-top: 2px;
}

.toggle-text-col {
  flex-direction: column;
}

.toggle-label {
  font-size: 12px;
  font-weight: 600;
  color: #FFFFFF;
}

.toggle-hint {
  font-size: 9px;
  color: rgba(255, 255, 255, 0.45);
}

.toggle-img {
  width: 38px;
  height: 27px;
}

.keypad {
  width: 168px;
  flex-direction: column;
  margin-top: 2px;
}

.krow {
  width: 100%;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 3px;
}

.kbtn {
  flex: 1;
  height: 22px;
  margin-right: 3px;
  border-radius: 11px;
  background-color: #262626;
  justify-content: center;
  align-items: center;
  border-width: 1.5px;
  border-style: solid;
  border-color: rgba(255, 255, 255, 0.18);
}

.kbtn-wide {
  flex: 5;
  height: 22px;
  margin-right: 3px;
