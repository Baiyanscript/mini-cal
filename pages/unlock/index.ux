  width: 100%;
  height: 28px;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  background-color: #262626;
  border-radius: 14px;
  padding-left: 12px;
  padding-right: 12px;
  border-width: 1.5px;
  border-style: solid;
  border-color: rgba(255, 255, 255, 0.18);
}

